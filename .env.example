# Copy this file to .env.local and fill in your keys.
# Never commit .env.local.

# Finnhub API (US stocks) - Get from: https://finnhub.io/
FINNHUB_API_KEY=

# Binance API (Crypto) - Get from: https://www.binance.com/en/my/settings/api-management
# Only READ permissions needed
BINANCE_API_KEY=

# TrueData API (Indian stocks/indices NSE/BSE) - Get from: https://truedata.in/
# Format: userid-password
TRUEDATA_API_KEY=
